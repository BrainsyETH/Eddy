{
  "name": "missouri-float-planner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src shared && npm run lint:tokens",
    "lint:tokens": "tsx scripts/check-tailwind-tokens.ts",
    "test": "tsx --test src/components/map/marker-pointer-priority.test.ts src/lib/admin-auth.test.ts src/lib/condition-snapshot.test.ts src/lib/security/machine-auth.test.ts src/lib/shuttle-plausibility.test.ts src/lib/uploads/community-image.test.ts scripts/security/segment-cache-policy.test.ts",
    "check:eddy-knowledge": "tsx scripts/check-eddy-knowledge.ts",
    "test:links": "tsx scripts/check-dead-links.ts",
    "db:import-rivers": "tsx scripts/import-nhd-rivers.ts",
    "db:import-gauges": "tsx scripts/fetch-gauge-stations.ts",
    "db:snap-access-points": "tsx scripts/snap-access-points.ts",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:gen-types": "npx supabase gen types typescript --project-id ilefwfpvphadsbptiaur --schema public > src/types/database.ts",
    "db:import-mile-markers": "tsx scripts/import-mile-markers.ts",
    "db:correct-miles": "tsx scripts/correct-access-point-miles.ts",
    "db:verify-directions": "tsx scripts/verify-river-directions.ts",
    "db:validate": "tsx scripts/validate-data.ts",
    "db:import-access-points": "tsx scripts/import-access-points-csv.ts",
    "db:import-services": "tsx scripts/import-services-csv.ts",
    "db:fix-gauges": "tsx scripts/fix-gauge-associations.ts",
    "db:sync-thresholds": "tsx scripts/sync-gauge-thresholds.ts",
    "db:import-rivers-tnm": "tsx scripts/import-nhd-rivers-from-tnm.ts",
    "data:build-outline": "tsx scripts/build-mo-outline.ts",
    "db:import-segments": "tsx scripts/import-float-segments.ts",
    "db:import-floatmissouri": "tsx scripts/import-floatmissouri.ts",
    "db:seed": "echo 'Run seed SQL files via Supabase CLI or SQL Editor. See scripts/run-seeds.ts for details.'",
    "db:setup": "npm run db:seed && npm run db:snap-access-points",
    "db:fix-geometry": "npm run db:import-rivers && npm run db:verify-directions && npm run db:snap-access-points",
    "video:dev": "cd remotion && npx remotion studio",
    "video:generate": "cd remotion && npx tsx scripts/generate-video.ts",
    "video:generate:assets": "cd remotion && npx tsx scripts/generate-video.ts --assets-only",
    "video:generate:render": "cd remotion && npx tsx scripts/generate-video.ts --render-only",
    "video:render": "cd remotion && npx remotion render Root tutorial-full out/eddy-tutorial-landscape.mp4",
    "video:render:vertical": "cd remotion && npx remotion render Root tutorial-full-vertical out/eddy-tutorial-vertical.mp4",
    "video:render:all": "npm run video:render && npm run video:render:vertical",
    "video:studio": "cd remotion && npx remotion studio",
    "promo:capture": "cd remotion && node scripts/capture-promo.mjs",
    "promo:render": "cd remotion && bash scripts/render-promo.sh"
  },
