{
  "name": "eddy-video-tutorial",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion video tutorial for Eddy - Missouri Float Trip Planner",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render Root tutorial-full out/eddy-tutorial-landscape.mp4",
    "render:vertical": "remotion render Root tutorial-full-vertical out/eddy-tutorial-vertical.mp4",
    "render:all": "npm run render && npm run render:vertical",
    "render:scene": "remotion render Root",
    "render:demo": "remotion render demo-walkthrough out/eddy-demo.mp4",
    "render:demo:short": "remotion render demo-walkthrough-short out/eddy-demo-30.mp4",
    "render:demo:feed": "remotion render demo-walkthrough-feed out/eddy-demo-4x5.mp4",
    "generate": "tsx scripts/generate-video.ts",
    "generate:assets": "tsx scripts/generate-video.ts --assets-only",
    "generate:render": "tsx scripts/generate-video.ts --render-only",
    "render:check-stills": "mkdir -p /tmp/stills && for comp in social-route-portrait social-section-portrait social-gauge social-trend-portrait social-digest; do remotion still --entry-point=src/index.ts --public-dir=./public \"$comp\" \"/tmp/stills/$comp.png\" --frame=120; done",
    "test:visual": "node test/visual-diff.mjs",
    "test:visual:update": "node test/visual-diff.mjs --update"
  },
  "dependencies": {
    "@remotion/cli": "4.0.242",
    "@remotion/renderer": "4.0.242",
    "@remotion/tailwind": "4.0.242",
    "autoprefixer": "^10",
    "openai": "^4.73.0",
    "postcss": "^8",
    "puppeteer": "^23.0.0",
    "react": "^18",
    "react-dom": "^18",
    "remotion": "4.0.242",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
